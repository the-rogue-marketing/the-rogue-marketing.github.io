---
layout: null
permalink: /sitemap
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/pages/ai-api-pricing-calculator/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  {% for page in site.pages %}
    {% unless page.sitemap == false or page.layout == null or page.url contains 'assets' or page.url contains 'css' or page.url contains 'js' or page.url == '/' or page.url contains 'calculator' %}
    <url>
      <loc>{{ site.url }}{{ site.baseurl }}{{ page.url | replace: '.html', '/' }}</loc>
      <lastmod>{% if page.last_modified_at %}{{ page.last_modified_at | date_to_xmlschema }}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</lastmod>
      <changefreq>weekly</changefreq>
      <priority>0.7</priority>
    </url>
    {% endunless %}
  {% endfor %}
  {% for post in site.posts %}
    <url>
      <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
      <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
      <changefreq>weekly</changefreq>
      <priority>0.8</priority>
    </url>
  {% endfor %}
</urlset>
